<Window x:Class="CoinCraft.App.Views.AccountEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar Conta" Height="360" Width="520" WindowStartupLocation="CenterOwner" WindowStyle="None" Icon="pack://application:,,,/CoinCraft.App;component/Icon.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{DynamicResource HeaderBackgroundBrush}" BorderBrush="{DynamicResource HeaderBorderBrush}" BorderThickness="0,0,0,1" Padding="10" MouseDown="OnHeaderMouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/CoinCraft.App;component/Icon.ico" Width="18" Height="18" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource HeaderForegroundBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource TitleBarButton}" Content="—" ToolTip="Minimizar" Click="OnMinimizeClick"/>
                    <Button Style="{StaticResource TitleBarButton}" Content="□" ToolTip="Maximizar/Restaurar" Margin="6,0,0,0" Click="OnToggleMaximizeClick"/>
                    <Button Style="{StaticResource TitleBarCloseButton}" Content="✕" ToolTip="Fechar" Margin="6,0,0,0" Click="OnCloseClick"/>
                </StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="1" Style="{StaticResource WindowContentCard}">
            <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Nome" VerticalAlignment="Center"/>
            <TextBox x:Name="NomeBox" Grid.Column="1" Margin="8,0,0,8"/>

            <TextBlock Text="Tipo" Grid.Row="1" VerticalAlignment="Center"/>
            <ComboBox x:Name="TipoCombo" Grid.Row="1" Grid.Column="1" Margin="8,0,0,8"/>

            <TextBlock Text="Saldo Inicial" Grid.Row="2" VerticalAlignment="Center"/>
            <TextBox x:Name="SaldoBox" Grid.Row="2" Grid.Column="1" Margin="8,0,0,8"/>

            <TextBlock Text="Ativa" Grid.Row="3" VerticalAlignment="Center"/>
            <CheckBox x:Name="AtivaCheck" Grid.Row="3" Grid.Column="1" Margin="8,0,0,8"/>

            <TextBlock Text="Cor (hex)" Grid.Row="4" VerticalAlignment="Center"/>
            <TextBox x:Name="CorBox" Grid.Row="4" Grid.Column="1" Margin="8,0,0,8"/>

            <TextBlock Text="Ícone" Grid.Row="5" VerticalAlignment="Center"/>
            <TextBox x:Name="IconeBox" Grid.Row="5" Grid.Column="1" Margin="8,0,0,8"/>
        </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" IsCancel="True" Margin="0,12,8,0"/>
            <Button Content="Salvar" Click="OnSaveClick" IsDefault="True" Margin="0,12,0,0"/>
            </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>