<Application x:Class="CoinCraft.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:s="clr-namespace:System;assembly=mscorlib">
    <Application.Resources>
        <!-- Recursos de tema dinâmico -->
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="AppForegroundBrush" Color="#FF000000"/>
        <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#F7F7F8"/>
        <SolidColorBrush x:Key="HeaderForegroundBrush" Color="#000000"/>
        <SolidColorBrush x:Key="HeaderBorderBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#E6E6E6"/>
        <SolidColorBrush x:Key="TitleBarButtonPressedBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="TitleBarCloseHoverBrush" Color="#FF5252"/>
        <SolidColorBrush x:Key="TitleBarClosePressedBrush" Color="#E53935"/>
        <SolidColorBrush x:Key="WindowContentBackgroundBrush" Color="#FAFAFA"/>
        <SolidColorBrush x:Key="WindowContentBorderBrush" Color="#DDDDDD"/>
        <CornerRadius x:Key="WindowContentCornerRadius">6</CornerRadius>
        <s:Double x:Key="WindowContentShadowOpacity">0.10</s:Double>
        <s:Double x:Key="WindowContentShadowBlur">8</s:Double>
        <s:Double x:Key="WindowContentShadowDepth">1</s:Double>
        
        <!-- Tipografia padrão mais legível em toda a aplicação -->
        <Style TargetType="Control">
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <!-- Estilos globais de botões de barra de título -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource HeaderForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TitleBarButtonHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TitleBarButtonPressedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TitleBarCloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TitleBarCloseHoverBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TitleBarClosePressedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WindowContentCard" TargetType="Border">
            <Setter Property="Padding" Value="16"/>
            <Setter Property="CornerRadius" Value="{DynamicResource WindowContentCornerRadius}"/>
            <Setter Property="Background" Value="{DynamicResource WindowContentBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WindowContentBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect 
                        BlurRadius="{DynamicResource WindowContentShadowBlur}"
                        ShadowDepth="{DynamicResource WindowContentShadowDepth}"
                        Opacity="{DynamicResource WindowContentShadowOpacity}"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Margin" Value="16"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="{DynamicResource HeaderBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource HeaderForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource HeaderBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5C6BC0"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
