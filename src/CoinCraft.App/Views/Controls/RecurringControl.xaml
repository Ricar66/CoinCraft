<UserControl x:Class="CoinCraft.App.Views.Controls.RecurringControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <StackPanel Orientation="Horizontal" Grid.Row="0">
      <TextBlock Text="Lançamentos Recorrentes" FontSize="20" FontWeight="Bold"/>
    </StackPanel>
    <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,8,0,8">
      <StackPanel.Resources>
        <Style TargetType="FrameworkElement">
          <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
      </StackPanel.Resources>
      <TextBlock Text="Conta:" VerticalAlignment="Center"/>
      <ComboBox x:Name="AccountFilter" Width="160" DisplayMemberPath="Nome" SelectedValuePath="Id"/>
      <TextBlock Text="Categoria:" VerticalAlignment="Center"/>
      <ComboBox x:Name="CategoryFilter" Width="160" DisplayMemberPath="Nome" SelectedValuePath="Id"/>
      <TextBlock Text="Freq." VerticalAlignment="Center"/>
      <ComboBox x:Name="FrequencyFilter" Width="160">
        <ComboBoxItem Content="Diario"/>
        <ComboBoxItem Content="Semanal"/>
        <ComboBoxItem Content="Mensal"/>
        <ComboBoxItem Content="Anual"/>
      </ComboBox>
      <TextBlock Text="Nome:" VerticalAlignment="Center"/>
      <TextBox x:Name="NameFilter" Width="160"/>
      <TextBlock Text="Próxima:" VerticalAlignment="Center"/>
      <DatePicker x:Name="FromPicker"/>
      <DatePicker x:Name="ToPicker"/>
      <Button Content="Aplicar" Click="OnApplyFiltersClick"/>
      <Button Content="Atualizar" Click="OnRefreshClick"/>
      <Button Content="Adicionar" Click="OnAddClick"/>
      <Button Content="Editar" Click="OnEditClick"/>
      <Button Content="Excluir" Click="OnDeleteClick"/>
      <TextBlock x:Name="StatusText" VerticalAlignment="Center"/>
    </StackPanel>
    <DataGrid Grid.Row="2" ItemsSource="{Binding Items}" AutoGenerateColumns="False" IsReadOnly="True" SelectedItem="{Binding Selected}">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*"/>
        <DataGridTextColumn Header="Frequência" Binding="{Binding Frequencia}" Width="140"/>
        <DataGridTextColumn Header="Próxima" Binding="{Binding NextRunDate}" Width="140"/>
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>