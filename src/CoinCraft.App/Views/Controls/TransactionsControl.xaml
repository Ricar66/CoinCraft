<UserControl x:Class="CoinCraft.App.Views.Controls.TransactionsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <StackPanel Orientation="Horizontal" Grid.Row="0">
      <TextBlock Text="Lançamentos" FontSize="20" FontWeight="Bold"/>
    </StackPanel>
    <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,8,0,8">
      <StackPanel.Resources>
        <Style TargetType="FrameworkElement">
          <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
      </StackPanel.Resources>
      <TextBlock Text="Período:" VerticalAlignment="Center"/>
      <DatePicker x:Name="FromPicker"/>
      <DatePicker x:Name="ToPicker"/>
      <TextBlock Text="Conta:" VerticalAlignment="Center"/>
      <ComboBox x:Name="AccountFilter" Width="160" DisplayMemberPath="Nome" SelectedValuePath="Id"/>
      <TextBlock Text="Categoria:" VerticalAlignment="Center"/>
      <ComboBox x:Name="CategoryFilter" Width="160" DisplayMemberPath="Nome" SelectedValuePath="Id"/>
      <Button Content="Aplicar" Click="OnApplyFiltersClick"/>
      <Button Content="Atualizar" Click="OnRefreshClick"/>
      <Button Content="Adicionar" Click="OnAddClick"/>
      <Button Content="Editar" Click="OnEditClick"/>
      <Button Content="Excluir" Click="OnDeleteClick"/>
      <TextBlock x:Name="StatusText" VerticalAlignment="Center"/>
    </StackPanel>
    <DataGrid Grid.Row="2" ItemsSource="{Binding Transactions}" AutoGenerateColumns="False" IsReadOnly="True" SelectedItem="{Binding Selected}">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Data" Binding="{Binding Data, StringFormat=d}" Width="100"/>
        <DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="100"/>
        <DataGridTextColumn Header="Valor" Binding="{Binding Valor}" Width="120"/>
        <DataGridTextColumn Header="Conta" Binding="{Binding AccountName}" Width="*"/>
        <DataGridTextColumn Header="Categoria" Binding="{Binding CategoryName}" Width="200"/>
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>