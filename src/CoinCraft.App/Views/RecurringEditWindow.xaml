<Window x:Class="CoinCraft.App.Views.RecurringEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recorrente" Height="520" Width="640" WindowStartupLocation="CenterOwner" WindowStyle="None" Icon="pack://application:,,,/CoinCraft.App;component/Icon.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{DynamicResource HeaderBackgroundBrush}" BorderBrush="{DynamicResource HeaderBorderBrush}" BorderThickness="0,0,0,1" Padding="10" MouseDown="OnHeaderMouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/CoinCraft.App;component/Icon.ico" Width="18" Height="18" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource HeaderForegroundBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource TitleBarButton}" Content="—" ToolTip="Minimizar" Click="OnMinimizeClick"/>
                    <Button Style="{StaticResource TitleBarButton}" Content="□" ToolTip="Maximizar/Restaurar" Margin="6,0,0,0" Click="OnToggleMaximizeClick"/>
                    <Button Style="{StaticResource TitleBarCloseButton}" Content="✕" ToolTip="Fechar" Margin="6,0,0,0" Click="OnCloseClick"/>
                </StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="1" Style="{StaticResource WindowContentCard}">
            <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Nome" VerticalAlignment="Center"/>
            <TextBox x:Name="NomeBox" Grid.Column="1" Margin="8,0,0,8"/>

            <TextBlock Text="Frequência" Grid.Row="1" VerticalAlignment="Center"/>
            <ComboBox x:Name="FrequenciaCombo" Grid.Row="1" Grid.Column="1" Margin="8,0,0,8"/>

            <TextBlock Text="Início" Grid.Row="2" VerticalAlignment="Center"/>
            <DatePicker x:Name="InicioPicker" Grid.Row="2" Grid.Column="1" Margin="8,0,0,8"/>

            <TextBlock Text="Término (opcional)" Grid.Row="3" VerticalAlignment="Center"/>
            <DatePicker x:Name="FimPicker" Grid.Row="3" Grid.Column="1" Margin="8,0,0,8"/>

            <TextBlock Text="Dia da Semana (0=Dom)" Grid.Row="4" VerticalAlignment="Center"/>
            <TextBox x:Name="DiaSemanaBox" Grid.Row="4" Grid.Column="1" Margin="8,0,0,8"/>

            <TextBlock Text="Dia do Mês (1..31)" Grid.Row="5" VerticalAlignment="Center"/>
            <TextBox x:Name="DiaMesBox" Grid.Row="5" Grid.Column="1" Margin="8,0,0,8"/>

            <CheckBox x:Name="AutoCheck" Grid.Row="6" Content="Lançar automaticamente"/>

            <TextBlock Text="Tipo" Grid.Row="7" VerticalAlignment="Center"/>
            <ComboBox x:Name="TipoCombo" Grid.Row="7" Grid.Column="1" Margin="8,0,0,8"/>

            <TextBlock Text="Valor" Grid.Row="8" VerticalAlignment="Center"/>
            <TextBox x:Name="ValorBox" Grid.Row="8" Grid.Column="1" Margin="8,0,0,8"/>

            <TextBlock Text="Conta" Grid.Row="9" VerticalAlignment="Center"/>
            <ComboBox x:Name="ContaCombo" Grid.Row="9" Grid.Column="1" Margin="8,0,0,8" DisplayMemberPath="Nome" SelectedValuePath="Id"/>

            <TextBlock Text="Categoria" Grid.Row="10" VerticalAlignment="Center"/>
            <ComboBox x:Name="CategoriaCombo" Grid.Row="10" Grid.Column="1" Margin="8,0,0,8" DisplayMemberPath="Nome" SelectedValuePath="Id"/>

            <TextBlock Text="Descrição" Grid.Row="11" VerticalAlignment="Center"/>
            <TextBox x:Name="DescricaoBox" Grid.Row="11" Grid.Column="1" Margin="8,0,0,8"/>

            <TextBlock Text="Conta Destino (Transferência)" Grid.Row="12" VerticalAlignment="Center"/>
            <ComboBox x:Name="ContaDestinoCombo" Grid.Row="12" Grid.Column="1" Margin="8,0,0,8" DisplayMemberPath="Nome" SelectedValuePath="Id"/>
        </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" IsCancel="True" Margin="0,12,8,0"/>
            <Button Content="Salvar" IsDefault="True" Click="OnSaveClick" Margin="0,12,0,0"/>
            </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>