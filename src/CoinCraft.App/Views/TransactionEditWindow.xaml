<Window x:Class="CoinCraft.App.Views.TransactionEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lançamento" Height="420" Width="600" WindowStartupLocation="CenterOwner" WindowStyle="None" Icon="pack://application:,,,/CoinCraft.App;component/Icon.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{DynamicResource HeaderBackgroundBrush}" BorderBrush="{DynamicResource HeaderBorderBrush}" BorderThickness="0,0,0,1" Padding="10" MouseDown="OnHeaderMouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/CoinCraft.App;component/Icon.ico" Width="18" Height="18" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource HeaderForegroundBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource TitleBarButton}" Content="—" ToolTip="Minimizar" Click="OnMinimizeClick"/>
                    <Button Style="{StaticResource TitleBarButton}" Content="□" ToolTip="Maximizar/Restaurar" Margin="6,0,0,0" Click="OnToggleMaximizeClick"/>
                    <Button Style="{StaticResource TitleBarCloseButton}" Content="✕" ToolTip="Fechar" Margin="6,0,0,0" Click="OnCloseClick"/>
                </StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="1" Style="{StaticResource WindowContentCard}">
            <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Data" VerticalAlignment="Center"/>
            <DatePicker x:Name="DataPicker" Grid.Column="1" Margin="8,0,0,8"/>

            <TextBlock Text="Tipo" Grid.Row="1" VerticalAlignment="Center"/>
            <ComboBox x:Name="TipoCombo" Grid.Row="1" Grid.Column="1" Margin="8,0,0,8"/>

            <TextBlock Text="Valor" Grid.Row="2" VerticalAlignment="Center"/>
            <TextBox x:Name="ValorBox" Grid.Row="2" Grid.Column="1" Margin="8,0,0,8"/>

            <TextBlock Text="Conta" Grid.Row="3" VerticalAlignment="Center"/>
            <ComboBox x:Name="ContaCombo" Grid.Row="3" Grid.Column="1" Margin="8,0,0,8" DisplayMemberPath="Nome" SelectedValuePath="Id"/>

            <TextBlock Text="Categoria" Grid.Row="4" VerticalAlignment="Center"/>
            <ComboBox x:Name="CategoriaCombo" Grid.Row="4" Grid.Column="1" Margin="8,0,0,8" DisplayMemberPath="Nome" SelectedValuePath="Id"/>

            <TextBlock Text="Descrição" Grid.Row="5" VerticalAlignment="Center"/>
            <TextBox x:Name="DescricaoBox" Grid.Row="5" Grid.Column="1" Margin="8,0,0,8"/>

            <TextBlock Text="Conta Destino (Transferência)" Grid.Row="6" VerticalAlignment="Center"/>
            <ComboBox x:Name="ContaDestinoCombo" Grid.Row="6" Grid.Column="1" Margin="8,0,0,8" DisplayMemberPath="Nome" SelectedValuePath="Id"/>

            <TextBlock Text="Comprovante" Grid.Row="7" VerticalAlignment="Center"/>
            <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,8">
                <Button x:Name="SelectAttachmentButton" Content="Selecionar arquivo…" Click="OnSelectAttachmentClick"/>
                <TextBlock x:Name="AttachmentNameText" Margin="8,0,0,0" VerticalAlignment="Center" Text="Nenhum arquivo selecionado"/>
                <Button x:Name="ClearAttachmentButton" Content="Remover" Margin="8,0,0,0" Click="OnClearAttachmentClick"/>
            </StackPanel>
        </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" IsCancel="True" Margin="0,12,8,0"/>
                <Button Content="Salvar" IsDefault="True" Click="OnSaveClick" Margin="0,12,0,0"/>
            </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>